{
  "manifest_version": 3,
  "name": "Habit Tracker",
  "short_name": "Habits",
  "version": "1.0.0",
  "description": "A dark, modern habit tracker to build better routines",
  "start_url": "/habbit-tracker/",
  "scope": "/habbit-tracker/",
  "display": "fullscreen",
  "background_color": "#121212",
  "theme_color": "#121212",
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "192": "icons/icon192.png",
    "512": "icons/icon512.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/scripts/background.js"
  }
}
